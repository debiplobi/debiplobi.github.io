---
import { ThemeToggle } from '../components/ThemeToggle';
import Layout from './Layout.astro';
import { HugeiconsIcon } from "@hugeicons/react";
import { ArrowLeft01Icon } from "@hugeicons/core-free-icons";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date?: Date;
    year?: number;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | JD.`} description={frontmatter.description}>
<div class="min-h-screen bg-background text-foreground flex flex-col items-center py-20 px-6 sm:px-12 selection:bg-primary/20">
    <main class="max-w-3xl w-full flex flex-col gap-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
        <div class="flex justify-between items-center w-full mb-8">
            <a href="/" class="text-muted-foreground hover:text-foreground inline-flex items-center gap-1.5 transition-colors w-fit">
                <HugeiconsIcon icon={ArrowLeft01Icon} className="w-4 h-4" /> Back home
            </a>
            <ThemeToggle client:load />
        </div>
        
        <header class="space-y-4 border-b border-border/50 pb-8">
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground">{frontmatter.title}</h1>
            <p class="text-lg text-muted-foreground/90">{frontmatter.description}</p>
            <div class="flex items-center gap-4 text-sm text-muted-foreground pt-2">
                {frontmatter.date && <time datetime={frontmatter.date.toISOString()}>{frontmatter.date.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}</time>}
                {frontmatter.year && <span>{frontmatter.year}</span>}
            </div>
        </header>

        <article class="prose prose-neutral dark:prose-invert prose-p:leading-relaxed prose-headings:tracking-tight max-w-none">
            <slot />
        </article>

        <footer class="pt-12 mt-12 border-t border-border/30 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-sm text-muted-foreground">
                &copy; {new Date().getFullYear()} John Doe. All rights reserved.
            </p>
        </footer>
    </main>
</div>
</Layout>
